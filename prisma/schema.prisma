generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                     String          @id @default(uuid())
  username               String
  email                  String          @unique
  phone                  String?
  jobTitle               String?
  avatar                 String?
  accountType            AccountType     @default(STAFF)
  password               String
  salesCommissionPercent Float           @default(0)
  wage                   Int             @default(0)
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
  permissionId           String?
  orders                 Order[]
  permission             Permission?     @relation(fields: [permissionId], references: [id])
  customers              Customer[]      @relation("CustomerToUser")
  message                Message[]
  targets                UserTarget[]
  stockMovements         StockMovement[] // تتبع من قام بحركة المخزون
}

model Permission {
  id       String @id @default(uuid())
  roleName String

  // المنتجات
  viewProducts   Boolean @default(false)
  addProducts    Boolean @default(false)
  editProducts   Boolean @default(false)
  deleteProducts Boolean @default(false)

  // التقارير
  viewReports   Boolean @default(false)
  addReports    Boolean @default(false)
  editReports   Boolean @default(false)
  deleteReports Boolean @default(false)

  // الطلبات
  viewOrders   Boolean @default(false)
  addOrders    Boolean @default(false)
  editOrders   Boolean @default(false)
  deleteOrders Boolean @default(false)

  // العملاء (تم دمج الفرد والجملة والتقويم في حقل واحد)
  viewCustomers   Boolean @default(false)
  addCustomers    Boolean @default(false)
  editCustomers   Boolean @default(false)
  deleteCustomers Boolean @default(false)

  // الموظفين
  viewEmployees   Boolean @default(false)
  addEmployees    Boolean @default(false)
  editEmployees   Boolean @default(false)
  deleteEmployees Boolean @default(false)

  // المصاريف
  viewExpenses   Boolean @default(false)
  addExpenses    Boolean @default(false)
  editExpenses   Boolean @default(false)
  deleteExpenses Boolean @default(false)

  // إحصائيات النظام
  viewAnalytics Boolean @default(false)

  // تصنيف المنتجات
  viewCategories   Boolean @default(false)
  addCategories    Boolean @default(false)
  editCategories   Boolean @default(false)
  deleteCategories Boolean @default(false)

  // الصلاحيات (لإدارة الأدوار نفسها)
  viewPermissions   Boolean @default(false)
  editPermissions   Boolean @default(false)
  addPermissions    Boolean @default(false)
  deletePermissions Boolean @default(false)

  accessSyria  Boolean @default(false) // الوصول لمستودعات سوريا
  accessTurkey Boolean @default(false) // الوصول لمستودعات تركيا
  users        User[]
}

model Category {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  products Product[]
}

model Product {
  id             Int             @id @default(autoincrement())
  name           String
  description    String?
  googleLink     String?
  categoryId     Int?
  createdAt      DateTime        @default(now())
  orderItems     OrderItem[]
  category       Category?       @relation(fields: [categoryId], references: [id])
  images         ProductImage[]
  targetProducts TargetProduct[]
  stocks         ProductStock[]
  stockMovements StockMovement[]
}

model Warehouse {
  id        Int             @id @default(autoincrement())
  name      String          @unique // مثلاً: "مستودع إدلب" أو "مستودع إسطنبول"
  location  String // سوريا أو تركيا
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  stocks    ProductStock[]
  orders    Order[] // لتحديد من أي مخزن خرج الطلب
  movements StockMovement[]
}

model ProductStock {
  id          Int       @id @default(autoincrement())
  productId   Int
  warehouseId Int
  quantity    Int       @default(0) // الكمية الفعلية في هذا الموقع
  price       Float     @default(0)
  discount    Float     @default(0)
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([productId, warehouseId])
}

model StockMovement {
  id          String       @id @default(uuid())
  productId   Int
  warehouseId Int
  userId      String? // الموظف المسؤول
  quantity    Int // موجبة للزيادة وسالبة للنقصان
  type        MovementType
  reason      String? // ملاحظات (شراء، بيع، تالف، تحويل)
  createdAt   DateTime     @default(now())

  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id])
}

enum MovementType {
  IN // توريد جديد
  OUT // مبيعات
  TRANSFER // تحويل بين سوريا وتركيا
  ADJUSTMENT // جرد وتصحيح
  RETURN // مرتجع
}

model UserTarget {
  id               String          @id @default(uuid())
  userId           String
  salesTargetValue Int[]           @default([])
  salesRewardValue Int[]           @default([])
  isActive         Boolean         @default(true)
  endedAt          DateTime?
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  products         TargetProduct[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model TargetProduct {
  id          String     @id @default(uuid())
  targetId    String
  productId   Int
  requiredQty Int[]
  rewardValue Int[]
  target      UserTarget @relation(fields: [targetId], references: [id], onDelete: Cascade)
  product     Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([targetId, productId])
}

model ProductImage {
  id        Int     @id @default(autoincrement())
  url       String
  type      String
  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Customer {
  id          String    @id @default(uuid())
  name        String    @unique
  phone       String[]
  countryCode String?
  phonestatus String?
  country     String?
  gender      String?
  age         String?
  source      String?
  city        String?
  rating      Int?
  status      String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  orders      Order[]
  users       User[]    @relation("CustomerToUser")
  message     Message[]
}

model Message {
  id         String   @id @default(uuid())
  message    String?
  customerId String
  userId     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Order {
  id              Int         @id @default(autoincrement())
  orderNumber     String      @unique
  usdToTryRateAtOrder Float?
  shippingPrice   Float?
  totalAmount     Float
  discount        Float       @default(0)
  finalAmount     Float
  paymentMethod   String
  receiverName    String?
  receiverPhone   String[]
  country         String?
  city            String?
  invoiceImage    String?
  municipality    String?
  fullAddress     String?
  deliveryNotes   String?
  googleMapsLink  String?
  amount          String?
  amountBank      String?
  deliveryMethod  String?
  additionalNotes String?
  status          String      @default("PENDING")
  customerId      String
  userId          String?
  warehouseId     Int?
  shippingId      Int?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  customer        Customer    @relation(fields: [customerId], references: [id])
  user            User?       @relation(fields: [userId], references: [id])
  items           OrderItem[]
  warehouse       Warehouse?  @relation(fields: [warehouseId], references: [id])
  shipping        shipping?   @relation(fields: [shippingId], references: [id])
}

model Expense {
  id          Int       @id @default(autoincrement())
  amount      Float
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model shipping{
  id          Int       @id @default(autoincrement())
  name        String    @unique
  price       Float
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  orders      Order[]
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  quantity  Int     @default(1)
  price     Float
  discount  Float
  orderId   Int
  productId Int
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])
}

enum AccountType {
  ADMIN
  MANAGER
  STAFF
}

model TrakingCompany {
  id        String   @id @default(uuid())
  name      String   @unique
  city      String?
  location  String?
  price     Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GeneralSetting {
  id              Int      @id @default(autoincrement())
  siteName        String?
  companyEmail    String?
  companyPhone    String?
  siteCurrency    String?  @default("USD")
  usdToTryRate    Float?   @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
